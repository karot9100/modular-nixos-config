{ config, pkgs, lib, ... }:

  let
    mods = config.mymodules;
  in

{

  imports = [
    ../modules
  ];

  options = {
    mymodules = {
      enable = lib.mkEnableOption "enable in nixos";
    };
  };

  config = lib.mkIf mods.enable {

    # Browsers
    chromium.enable         = true;
    firefox.enable          = true;

    # Cli tools
    yt-dlp.enable           = true;

    # Desktop-tools
    appimage.enable         = true;
    # Dev
    virt-manager.enable     = false;
    docker.enable           = false;
    java.enable             = false;
    claude.enable           = true;

    # Editors
    gimp.enable             = false;
    vim.enable              = true;
    vscode.enable           = false;

    # File Browsers
    thunar.enable           = true;
    nautilus.enable         = true;

    # Gaming
    gamemode.enable         = true;
    perm-pkgs.enable        = true;
    steam.enable            = true;
    wine.enable             = true;

    # Media
    media.enable            = true;
    music.enable            = true;
    screenshot.enable       = true;
    video.enable            = true;

    # Office
    libreoffice.enable      = false;

    # Terminals
    alacritty.enable        = true;

    # Desktops
    hyprland.enable         = true;

    # Hardware
    input.enable            = true;
    nvidia.enable           = true;
    nvidia.batterySaver     = true;
    power-management.enable = true;
    lenovo-legion.enable    = true;
    printing.enable         = true;
    sensors.enable          = true;
    sound.enable            = true;
    storage.enable          = true;

    # System
    base.enable             = true;
    bash.enable             = true;
    dotfiles.enable         = true;
    keyring.enable          = true;
    networking.enable       = true;
    theme.enable            = true;
    users.enable            = true;

  };



}
